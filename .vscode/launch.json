{
  // 🐞 Debugging de Nest JS (backend)
  // Cada configuración invoca directamente el CLI de Nest con el node del editor,
  // igual que los scripts build:prod / build:test de package.json.
  // No se usa pnpm como runtimeExecutable porque el editor lanza el debugger sin el
  // PATH de fnm, y el binario de pnpm solo existe dentro del multishell efímero de fnm.
  //
  // ⚠️ Los flags de abajo duplican los de los scripts debug:* de package.json.
  // Si cambias un script debug:*, actualiza también su configuración aquí.
  "version": "0.2.0",
  "configurations": [
    {
      // equivale a: pnpm debug:local -> environments/.env.localhost
      "name": "🐞 Nest: debug local host",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/@nestjs/cli/bin/nest.js",
      "args": ["start", "--debug", "9000", "--watch", "--env-file", "environments/.env.localhost"],
      // nest start --watch reinicia el proceso hijo, este es el que expone el inspector
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    },
    {
      // equivale a: pnpm debug:test -> environments/.env.test
      "name": "🐞 Nest: debug pruebas",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/@nestjs/cli/bin/nest.js",
      "args": ["start", "--debug", "9000", "--watch", "--env-file", "environments/.env.test"],
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    },
    {
      // equivale a: pnpm debug:prod -> environments/.env.production
      "name": "🐞 Nest: debug producción",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/node_modules/@nestjs/cli/bin/nest.js",
      "args": ["start", "--debug", "9000", "--watch", "--env-file", "environments/.env.production"],
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    },
    {
      // Para cuando el script debug:* ya se está ejecutando manualmente en la terminal.
      // El entorno lo define el script que se haya ejecutado, no esta configuración.
      "name": "🔗 Nest: attach al proceso (puerto 9000)",
      "type": "node",
      "request": "attach",
      "port": 9000,
      "address": "localhost",
      "cwd": "${workspaceFolder}",
      // vuelve a adjuntarse cuando --watch reinicia el proceso
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/**/*.js"]
    }
  ]
}
